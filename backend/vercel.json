{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "app.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/update-prices",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/daily-scrape",
      "schedule": "0 21 * * *"
    }
  ]
}
